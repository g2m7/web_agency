# ─── Copy this to .env on your VPS and fill in real values ──────────
# ─── Core ───────────────────────────────────────────
PAYLOAD_SECRET=<generate-a-random-64-char-hex>
DB_NAME=web_agency
DB_USER=web_agency
DB_PASSWORD=<set-a-strong-password>
DATABASE_URL=postgres://web_agency:<password>@localhost:5432/web_agency
NEXT_PUBLIC_SERVER_URL=https://sarbaa.com
PORT=3006

# ─── Email ──────────────────────────────────────────
RESEND_API_KEY=

# ─── Payments ───────────────────────────────────────
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
POLAR_API_KEY=
POLAR_WEBHOOK_SECRET=

# ─── Deployment ─────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ─── Auth ───────────────────────────────────────────
API_KEY_INTERNAL=

# ─── Monitoring ─────────────────────────────────────
UPTIME_ROBOT_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
